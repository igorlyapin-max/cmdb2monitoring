flowchart TB
    subgraph devhost[Dev/Test host]
        monui[monitoring-ui-api :5090]
        wh[cmdbwebhooks2kafka 0.0.0.0:5080]
        conv[cmdbkafka2zabbix :5081]
        api[zabbixrequests2api :5082]
        bind[zabbixbindings2cmdbuild :5083]
        rules[rules JSON]
        state[state/*.json]
    end

    subgraph docker[Docker host]
        kafka[(Kafka :9092)]
        cmdb[CMDBuild :8090]
        zbx[Zabbix :8081]
    end

    subgraph external[External/Future]
        idp[IdP / MS AD]
        elk[ELK]
    end

    browser[Browser] -->|HTTP :5090| monui
    monui -->|SAML2/OAuth2 + LDAP groups :443/:80/:636/:389| idp
    monui -->|CMDB REST :8090| cmdb
    monui -->|Zabbix JSON-RPC :8081| zbx
    monui -->|Kafka read-only :9092| kafka
    monui -->|GET /health :5080| wh
    monui -->|GET /health :5081| conv
    monui -->|GET /health :5082| api
    monui -->|GET /health :5083| bind
    monui -->|POST /admin/reload-rules :5081| conv
    cmdb -->|HTTP webhook :5080 via 192.168.202.100| wh
    wh -->|produce :9092| kafka
    kafka -->|consume :9092| conv
    rules -->|local FS| conv
    conv -->|CMDB REST resolver :8090| cmdb
    conv -->|produce :9092| kafka
    kafka -->|consume :9092| api
    api -->|JSON-RPC :8081| zbx
    api -->|produce binding :9092| kafka
    kafka -->|consume binding :9092| bind
    bind -->|CMDB REST binding write :8090| cmdb
    wh --> state
    conv --> state
    api --> state
    bind --> state
    kafka -. log shipping :9200 .-> elk
