  "hostStatusSelectionRules": [
    {
      "name": "c2m-demo-disabled-host",
      "priority": 10,
      "when": {
        "allRegex": [
          {
            "field": "className",
            "pattern": "(?i)^C2MTestCI$"
          },
          {
            "field": "code",
            "pattern": "(?i)^C2M-DEMO-012-DISABLED-STATUS$"
          }
        ]
      },
      "hostStatus": {
        "name": "disabled",
        "status": 1
      }
    }
