  "hostMacroSelectionRules": [
    {
      "name": "c2m-demo-code-macro",
      "priority": 10,
      "when": {
        "allRegex": [
          {
            "field": "className",
            "pattern": "(?i)^C2MTestCI$"
          }
        ]
      },
      "hostMacros": [
        {
          "macro": "{$C2M_DEMO_CODE}",
          "valueTemplate": "<#= Model.Code #>",
          "description": "Demo CMDBuild object code"
        }
      ]
    }
  ],
  "inventorySelectionRules": [
    {
      "name": "c2m-demo-code-inventory-alias",
      "priority": 10,
      "when": {
        "allRegex": [
          {
            "field": "className",
            "pattern": "(?i)^C2MTestCI$"
          }
        ]
      },
      "inventoryFields": [
        {
          "field": "alias",
          "valueTemplate": "<#= Model.Code #>"
        }
      ]
    }
