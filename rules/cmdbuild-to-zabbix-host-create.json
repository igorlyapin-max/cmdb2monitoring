{
  "schemaVersion": "0.1",
  "name": "cmdbuild-computer-to-zabbix-host-lifecycle",
  "description": "Conversion rules for CMDBuild Computer-derived webhook events into Zabbix JSON-RPC payloads.",
  "source": {
    "topic": "cmdbuild.webhooks.dev",
    "supportedEvents": [
      "create",
      "update",
      "delete"
    ],
    "hostCreateEvents": [
      "create"
    ],
    "entityClasses": [
      "Computer",
      "Notebook",
      "PC",
      "Server",
      "tk"
    ],
    "fields": {
      "entityId": {
        "source": "id",
        "required": true
      },
      "code": {
        "source": "code",
        "required": false
      },
      "className": {
        "source": "className",
        "required": true
      },
      "ipAddress": {
        "source": "ip_address",
        "sources": [
          "ip_address",
          "ip",
          "IPAddress",
          "ipAddress"
        ],
        "required": false,
        "validationRegex": "^(?:(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.){3}(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})$"
      },
      "profileIpAddress": {
        "source": "profile",
        "cmdbAttribute": "mgmt",
        "required": false,
        "validationRegex": "^(?:(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.){3}(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})$"
      },
      "profile2IpAddress": {
        "source": "profile2",
        "cmdbAttribute": "mgmt2",
        "required": false,
        "validationRegex": "^(?:(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.){3}(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})$"
      },
      "interfaceIpAddress": {
        "source": "interface",
        "cmdbAttribute": "iLo",
        "required": false,
        "validationRegex": "^(?:(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.){3}(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})$"
      },
      "interface2IpAddress": {
        "source": "interface2",
        "cmdbAttribute": "iLo2",
        "required": false,
        "validationRegex": "^(?:(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.){3}(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})$"
      },
      "dnsName": {
        "source": "dns_name",
        "sources": [
          "dns_name",
          "fqdn",
          "host_dns",
          "hostname",
          "dnsName"
        ],
        "required": false,
        "validationRegex": "^(?=.{1,253}$)([A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)*[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?$"
      },
      "profileDnsName": {
        "source": "profile_dns",
        "required": false,
        "validationRegex": "^(?=.{1,253}$)([A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)*[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?$"
      },
      "description": {
        "source": "description",
        "required": false
      },
      "os": {
        "source": "OS",
        "required": false,
        "validationRegex": "(?i)^(windows|windows server|linux|vmware|105130|105152|105146|105161)$"
      },
      "zabbixTag": {
        "source": "zabbixTag",
        "required": false,
        "validationRegex": "(?i)^(tag[1-3]|106857|106852|106850)$"
      }
    }
  },
  "zabbix": {
    "apiEndpoint": "http://localhost:8081/api_jsonrpc.php",
    "apiVersionDetected": "7.0.25",
    "method": "host.create",
    "auth": {
      "mode": "configuredTokenOrLogin",
      "tokenConfigKey": "Zabbix:ApiToken",
      "loginConfigKeys": {
        "user": "Zabbix:User",
        "password": "Zabbix:Password"
      }
    },
    "requiredHostCreateFields": [
      "host",
      "interfaces",
      "groups"
    ],
    "expectedMonitoringFields": [
      "host",
      "name",
      "interfaces[].ip",
      "interfaces[].dns",
      "interfaces[].useip",
      "templates[].templateid",
      "tags[].tag",
      "tags[].value",
      "groups[].groupid"
    ]
  },
  "lookups": {
    "hostGroups": [
      {
        "name": "Applications",
        "groupid": "19"
      },
      {
        "name": "Databases",
        "groupid": "20"
      },
      {
        "name": "Discovered hosts",
        "groupid": "5"
      },
      {
        "name": "Hypervisors",
        "groupid": "7"
      },
      {
        "name": "Linux servers",
        "groupid": "2"
      },
      {
        "name": "Virtual machines",
        "groupid": "6"
      },
      {
        "name": "Zabbix servers",
        "groupid": "4"
      }
    ],
    "templates": [
      {
        "name": "Linux by Zabbix agent",
        "templateid": "10001"
      },
      {
        "name": "Windows by Zabbix agent",
        "templateid": "10081"
      },
      {
        "name": "ICMP Ping",
        "templateid": "10564"
      },
      {
        "name": "Zabbix agent",
        "templateid": "10561"
      },
      {
        "name": "Zabbix agent active",
        "templateid": "10562"
      },
      {
        "name": "Generic by SNMP",
        "templateid": "10563"
      },
      {
        "name": "Linux by SNMP",
        "templateid": "10248"
      },
      {
        "name": "Windows by SNMP",
        "templateid": "10249"
      },
      {
        "name": "Network Generic Device by SNMP",
        "templateid": "10226"
      },
      {
        "name": "HP iLO by SNMP",
        "templateid": "10256"
      },
      {
        "name": "Zabbix server health",
        "templateid": "10047"
      }
    ]
  },
  "defaults": {
    "host": {
      "status": 0,
      "inventory_mode": 0
    },
    "hostGroups": [
      {
        "name": "Linux servers",
        "groupid": "2"
      }
    ],
    "templates": [
      {
        "name": "ICMP Ping",
        "templateid": "10564"
      },
      {
        "name": "Linux by Zabbix agent",
        "templateid": "10001"
      }
    ],
    "agentInterface": {
      "type": 1,
      "main": 1,
      "useip": 1,
      "dns": "",
      "port": "10050"
    },
    "snmpInterface": {
      "type": 2,
      "main": 1,
      "useip": 1,
      "dns": "",
      "port": "161",
      "details": {
        "version": 2,
        "bulk": 1,
        "community": "{$SNMP_COMMUNITY}"
      }
    },
    "interfaceProfiles": {
      "agent": {
        "type": 1,
        "main": 1,
        "useip": 1,
        "dns": "",
        "port": "10050"
      },
      "snmp": {
        "type": 2,
        "main": 1,
        "useip": 1,
        "dns": "",
        "port": "161",
        "details": {
          "version": 2,
          "bulk": 1,
          "community": "{$SNMP_COMMUNITY}"
        }
      },
      "ipmi": {
        "type": 3,
        "main": 1,
        "useip": 1,
        "dns": "",
        "port": "623"
      },
      "interface": {
        "type": 2,
        "main": 1,
        "useip": 1,
        "dns": "",
        "port": "161",
        "details": {
          "version": 2,
          "bulk": 1,
          "community": "{$SNMP_COMMUNITY}"
        }
      },
      "interface2": {
        "type": 2,
        "main": 0,
        "useip": 1,
        "dns": "",
        "port": "161",
        "details": {
          "version": 2,
          "bulk": 1,
          "community": "{$SNMP_COMMUNITY}"
        }
      },
      "jmx": {
        "type": 4,
        "main": 1,
        "useip": 1,
        "dns": "",
        "port": "12345"
      }
    },
    "hostStatus": {
      "status": 0,
      "name": "monitored"
    },
    "hostMacros": [
      {
        "macro": "{$CMDB_CLASS}",
        "valueTemplate": "<#= Model.ClassName #>",
        "description": "CMDBuild source class"
      },
      {
        "macro": "{$CMDB_ID}",
        "valueTemplate": "<#= Model.EntityId #>",
        "description": "CMDBuild object id"
      }
    ],
    "inventoryFields": [
      {
        "field": "os",
        "valueTemplate": "<#= Model.OperatingSystem #>"
      },
      {
        "field": "asset_tag",
        "valueTemplate": "<#= Model.EntityId #>"
      }
    ],
    "tlsPsk": {
      "name": "none",
      "tls_connect": 1,
      "tls_accept": 1
    },
    "maintenances": [],
    "valueMaps": [],
    "tags": [
      {
        "tag": "source",
        "value": "cmdbuild"
      },
      {
        "tag": "cmdb.class",
        "valueTemplate": "<#= Model.ClassName #>"
      },
      {
        "tag": "cmdb.id",
        "valueTemplate": "<#= Model.EntityId #>"
      }
    ]
  },
  "normalization": {
    "hostName": {
      "inputPriority": [
        "code",
        "id"
      ],
      "prefixTemplate": "cmdb-<#= Model.ClassName #>-",
      "regexReplacements": [
        {
          "pattern": "[^A-Za-z0-9_.-]+",
          "replacement": "-"
        },
        {
          "pattern": "^-+|-+$",
          "replacement": ""
        }
      ],
      "lowercase": true,
      "fallbackTemplate": "cmdb-<#= Model.ClassName #>-<#= Model.EntityId #>"
    },
    "visibleName": {
      "template": "<#= Model.ClassName #> <#= Model.Code ?? Model.EntityId #>"
    }
  },
  "eventRoutingRules": [
    {
      "eventType": "create",
      "method": "host.create",
      "templateName": "hostCreateJsonRpcRequestLines",
      "requiresZabbixHostId": false,
      "requiredFields": [
        "entityId",
        "className",
        "interfaceAddress"
      ],
      "publish": true
    },
    {
      "eventType": "update",
      "method": "host.update",
      "templateName": "hostUpdateJsonRpcRequestLines",
      "requiresZabbixHostId": true,
      "fallbackMethod": "host.get",
      "fallbackTemplateName": "hostGetByHostJsonRpcRequestLines",
      "requiredFields": [
        "entityId",
        "className",
        "interfaceAddress"
      ],
      "publish": true
    },
    {
      "eventType": "delete",
      "method": "host.delete",
      "templateName": "hostDeleteJsonRpcRequestLines",
      "requiresZabbixHostId": true,
      "fallbackMethod": "host.get",
      "fallbackTemplateName": "hostGetByHostJsonRpcRequestLines",
      "requiredFields": [
        "entityId",
        "className"
      ],
      "publish": true
    }
  ],
  "hostProfiles": [
    {
      "name": "main",
      "priority": 10,
      "when": {
        "always": true
      },
      "hostNameTemplate": "cmdb-<#= Model.ClassName #>-<#= Model.Code ?? Model.EntityId #>",
      "visibleNameTemplate": "<#= Model.ClassName #> <#= Model.Code ?? Model.EntityId #>",
      "interfaces": [
        {
          "name": "main-agent-ip",
          "priority": 10,
          "interfaceProfileRef": "agent",
          "mode": "ip",
          "valueField": "ipAddress",
          "when": {
            "fieldExists": "ipAddress"
          }
        },
        {
          "name": "main-agent-dns",
          "priority": 20,
          "fallback": true,
          "interfaceProfileRef": "agent",
          "mode": "dns",
          "valueField": "dnsName",
          "when": {
            "fieldExists": "dnsName"
          }
        },
        {
          "name": "interface-snmp-ip",
          "priority": 30,
          "interfaceProfileRef": "interface",
          "mode": "ip",
          "valueField": "interfaceIpAddress",
          "when": {
            "fieldExists": "interfaceIpAddress"
          }
        },
        {
          "name": "interface2-snmp-ip",
          "priority": 40,
          "interfaceProfileRef": "interface2",
          "mode": "ip",
          "valueField": "interface2IpAddress",
          "when": {
            "fieldExists": "interface2IpAddress"
          }
        }
      ]
    },
    {
      "name": "profile",
      "priority": 20,
      "createOnUpdateWhenMissing": true,
      "when": {
        "allRegex": [
          {
            "field": "className",
            "pattern": "(?i)^server$"
          }
        ],
        "anyRegex": [
          {
            "field": "profileIpAddress",
            "pattern": ".+"
          },
          {
            "field": "eventType",
            "pattern": "(?i)^delete$"
          }
        ]
      },
      "hostNameTemplate": "cmdb-<#= Model.ClassName #>-<#= Model.Code ?? Model.EntityId #>-profile",
      "visibleNameTemplate": "<#= Model.ClassName #> <#= Model.Code ?? Model.EntityId #> profile",
      "interfaces": [
        {
          "name": "profile-host-snmp-ip",
          "priority": 10,
          "interfaceProfileRef": "snmp",
          "mode": "ip",
          "valueField": "profileIpAddress",
          "when": {
            "fieldExists": "profileIpAddress"
          }
        }
      ]
    },
    {
      "name": "profile2",
      "priority": 30,
      "createOnUpdateWhenMissing": true,
      "when": {
        "allRegex": [
          {
            "field": "className",
            "pattern": "(?i)^server$"
          }
        ],
        "anyRegex": [
          {
            "field": "profile2IpAddress",
            "pattern": ".+"
          },
          {
            "field": "eventType",
            "pattern": "(?i)^delete$"
          }
        ]
      },
      "hostNameTemplate": "cmdb-<#= Model.ClassName #>-<#= Model.Code ?? Model.EntityId #>-profile2",
      "visibleNameTemplate": "<#= Model.ClassName #> <#= Model.Code ?? Model.EntityId #> profile2",
      "interfaces": [
        {
          "name": "profile2-host-snmp-ip",
          "priority": 10,
          "interfaceProfileRef": "snmp",
          "mode": "ip",
          "valueField": "profile2IpAddress",
          "when": {
            "fieldExists": "profile2IpAddress"
          }
        }
      ]
    }
  ],
  "selectionPolicy": {
    "ruleOrder": "ascendingPriority",
    "groupSelection": "mergeAllMatchesOrFallback",
    "templateSelection": "mergeAllMatchesOrFallback",
    "hostProfileSelection": "allMatchedProfiles",
    "interfaceSelection": "firstMatchOrFallback",
    "tagSelection": "mergeDefaultsAndMatches",
    "deduplicateBy": {
      "hostGroups": "groupid",
      "templates": "templateid",
      "tags": "tag"
    }
  },
  "groupSelectionRules": [
    {
      "name": "additional-profile-hosts",
      "priority": 5,
      "when": {
        "anyRegex": [
          {
            "field": "hostProfile",
            "pattern": "(?i)^(profile|profile2)$"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Discovered hosts",
          "groupid": "5"
        }
      ]
    },
    {
      "name": "databases",
      "priority": 10,
      "when": {
        "anyRegex": [
          {
            "field": "className",
            "pattern": "(?i)(database|db)"
          },
          {
            "field": "description",
            "pattern": "(?i)\\b(db|database|postgres|postgresql|mysql|mssql|oracle)\\b"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Databases",
          "groupid": "20"
        }
      ]
    },
    {
      "name": "applications",
      "priority": 20,
      "when": {
        "anyRegex": [
          {
            "field": "className",
            "pattern": "(?i)(application|app)"
          },
          {
            "field": "description",
            "pattern": "(?i)\\b(app|application|service)\\b"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Applications",
          "groupid": "19"
        }
      ]
    },
    {
      "name": "hypervisors",
      "priority": 30,
      "when": {
        "anyRegex": [
          {
            "field": "className",
            "pattern": "(?i)(hypervisor|esxi|vmware|kvm)"
          },
          {
            "field": "description",
            "pattern": "(?i)\\b(hypervisor|esxi|vmware|kvm)\\b"
          },
          {
            "field": "os",
            "pattern": "(?i)^(vmware|105161)$"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Hypervisors",
          "groupid": "7"
        }
      ]
    },
    {
      "name": "virtual-machines",
      "priority": 40,
      "when": {
        "anyRegex": [
          {
            "field": "className",
            "pattern": "(?i)(virtual|vm)"
          },
          {
            "field": "code",
            "pattern": "(?i)^vm[-_.]"
          },
          {
            "field": "description",
            "pattern": "(?i)\\b(vm|virtual machine|virtual)\\b"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Virtual machines",
          "groupid": "6"
        }
      ]
    },
    {
      "name": "network-devices",
      "priority": 50,
      "when": {
        "anyRegex": [
          {
            "field": "className",
            "pattern": "(?i)(network|switch|router)"
          },
          {
            "field": "description",
            "pattern": "(?i)\\b(snmp|switch|router|network)\\b"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Discovered hosts",
          "groupid": "5"
        }
      ]
    },
    {
      "name": "linux-os",
      "priority": 55,
      "when": {
        "anyRegex": [
          {
            "field": "os",
            "pattern": "(?i)^(linux|105146)$"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Linux servers",
          "groupid": "2"
        }
      ]
    },
    {
      "name": "windows-os",
      "priority": 56,
      "when": {
        "anyRegex": [
          {
            "field": "os",
            "pattern": "(?i)^(windows|windows server|105130|105152)$"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Discovered hosts",
          "groupid": "5"
        }
      ]
    },
    {
      "name": "workstations",
      "priority": 60,
      "when": {
        "anyRegex": [
          {
            "field": "className",
            "pattern": "(?i)^(notebook|pc)$"
          },
          {
            "field": "code",
            "pattern": "(?i)^(nb|pc)[-_.]"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Discovered hosts",
          "groupid": "5"
        }
      ]
    },
    {
      "name": "linux-servers",
      "priority": 70,
      "when": {
        "anyRegex": [
          {
            "field": "os",
            "pattern": "(?i)^(linux|105146)$"
          },
          {
            "field": "description",
            "pattern": "(?i)\\blinux\\b"
          }
        ]
      },
      "hostGroups": [
        {
          "name": "Linux servers",
          "groupid": "2"
        }
      ]
    },
    {
      "name": "default-linux",
      "priority": 1000,
      "fallback": true,
      "when": {
        "always": true
      },
      "hostGroupsRef": "defaults.hostGroups"
    }
  ],
  "templateSelectionRules": [
    {
      "name": "network-snmp",
      "priority": 10,
      "when": {
        "anyRegex": [
          {
            "field": "className",
            "pattern": "(?i)(network|switch|router)"
          },
          {
            "field": "description",
            "pattern": "(?i)\\b(snmp|switch|router|network)\\b"
          }
        ]
      },
      "templates": [
        {
          "name": "ICMP Ping",
          "templateid": "10564"
        },
        {
          "name": "Network Generic Device by SNMP",
          "templateid": "10226"
        }
      ]
    },
    {
      "name": "generic-snmp",
      "priority": 20,
      "when": {
        "anyRegex": [
          {
            "field": "description",
            "pattern": "(?i)\\bsnmp\\b"
          }
        ]
      },
      "templates": [
        {
          "name": "ICMP Ping",
          "templateid": "10564"
        },
        {
          "name": "Generic by SNMP",
          "templateid": "10563"
        }
      ]
    },
    {
      "name": "linux-agent",
      "priority": 25,
      "when": {
        "anyRegex": [
          {
            "field": "os",
            "pattern": "(?i)^(linux|105146)$"
          }
        ]
      },
      "templates": [
        {
          "name": "ICMP Ping",
          "templateid": "10564"
        },
        {
          "name": "Linux by Zabbix agent",
          "templateid": "10001"
        }
      ]
    },
    {
      "name": "vmware-agent",
      "priority": 26,
      "when": {
        "anyRegex": [
          {
            "field": "os",
            "pattern": "(?i)^(vmware|105161)$"
          }
        ]
      },
      "templates": [
        {
          "name": "ICMP Ping",
          "templateid": "10564"
        },
        {
          "name": "Zabbix agent",
          "templateid": "10561"
        }
      ]
    },
    {
      "name": "windows-agent",
      "priority": 30,
      "when": {
        "anyRegex": [
          {
            "field": "className",
            "pattern": "(?i)windows"
          },
          {
            "field": "description",
            "pattern": "(?i)\\b(win|windows)\\b"
          },
          {
            "field": "os",
            "pattern": "(?i)^(windows|windows server|105130|105152)$"
          }
        ]
      },
      "templates": [
        {
          "name": "ICMP Ping",
          "templateid": "10564"
        },
        {
          "name": "Windows by Zabbix agent",
          "templateid": "10081"
        }
      ]
    },
    {
      "name": "server-main-additional-interfaces",
      "priority": 39,
      "when": {
        "allRegex": [
          {
            "field": "className",
            "pattern": "(?i)^server$"
          },
          {
            "field": "hostProfile",
            "pattern": "(?i)^main$"
          }
        ],
        "anyRegex": [
          {
            "field": "interfaceIpAddress",
            "pattern": ".+"
          },
          {
            "field": "interface2IpAddress",
            "pattern": ".+"
          }
        ]
      },
      "templates": [
        {
          "name": "ICMP Ping",
          "templateid": "10564"
        },
        {
          "name": "HP iLO by SNMP",
          "templateid": "10256"
        }
      ]
    },
    {
      "name": "additional-profile-snmp",
      "priority": 40,
      "when": {
        "anyRegex": [
          {
            "field": "hostProfile",
            "pattern": "(?i)^(profile|profile2)$"
          }
        ]
      },
      "templates": [
        {
          "name": "ICMP Ping",
          "templateid": "10564"
        },
        {
          "name": "Generic by SNMP",
          "templateid": "10563"
        }
      ]
    },
    {
      "name": "default-linux-agent",
      "priority": 1000,
      "fallback": true,
      "when": {
        "always": true
      },
      "templatesRef": "defaults.templates"
    }
  ],
  "templateConflictRules": [
    {
      "name": "hp-interface-removes-conflicting-agent-templates",
      "whenTemplateIds": [
        "10256"
      ],
      "removeTemplateIds": [
        "10564",
        "10001",
        "10081",
        "10561",
        "10562"
      ],
      "reason": "HP iLO by SNMP already contains item key icmpping and populates inventory field Name; keeping ICMP Ping or agent templates with it makes Zabbix reject host.create/host.update."
    },
    {
      "name": "generic-snmp-removes-conflicting-agent-templates",
      "whenTemplateIds": [
        "10563"
      ],
      "removeTemplateIds": [
        "10564",
        "10001",
        "10081",
        "10561",
        "10562"
      ],
      "reason": "Generic by SNMP already contains item key icmpping and populates inventory field Name; keeping ICMP Ping or agent templates with it makes Zabbix reject host.create/host.update."
    }
  ],
  "interfaceAddressRules": [
    {
      "name": "prefer-ip-address",
      "priority": 10,
      "mode": "ip",
      "valueField": "ipAddress",
      "when": {
        "fieldExists": "ipAddress"
      }
    },
    {
      "name": "fallback-dns-name",
      "priority": 20,
      "fallback": true,
      "mode": "dns",
      "valueField": "dnsName",
      "when": {
        "fieldExists": "dnsName"
      }
    }
  ],
  "interfaceSelectionRules": [
    {
      "name": "snmp-interface",
      "priority": 10,
      "when": {
        "anyRegex": [
          {
            "field": "className",
            "pattern": "(?i)(network|switch|router)"
          },
          {
            "field": "description",
            "pattern": "(?i)\\bsnmp\\b"
          }
        ]
      },
      "interfaceRef": "snmpInterface"
    },
    {
      "name": "default-agent-interface",
      "priority": 1000,
      "fallback": true,
      "when": {
        "always": true
      },
      "interfaceRef": "agentInterface"
    }
  ],
