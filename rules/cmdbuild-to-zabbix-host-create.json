  "tagSelectionRules": [
    {
      "name": "event-create",
      "priority": 10,
      "when": {
        "anyRegex": [
          {
            "field": "eventType",
            "pattern": "(?i)^create$"
          }
        ]
      },
      "tags": [
        {
          "tag": "cmdb.event",
          "value": "create"
        }
      ]
    },
    {
      "name": "event-update",
      "priority": 20,
      "when": {
        "anyRegex": [
          {
            "field": "eventType",
            "pattern": "(?i)^update$"
          }
        ]
      },
      "tags": [
        {
          "tag": "cmdb.event",
          "value": "update"
        }
      ]
    },
    {
      "name": "event-delete",
      "priority": 30,
      "when": {
        "anyRegex": [
          {
            "field": "eventType",
            "pattern": "(?i)^delete$"
          }
        ]
      },
      "tags": [
        {
          "tag": "cmdb.event",
          "value": "delete"
        }
      ]
    },
    {
      "name": "host-profile-main",
      "priority": 40,
      "when": {
        "anyRegex": [
          {
            "field": "hostProfile",
            "pattern": "(?i)^main$"
          }
        ]
      },
      "tags": [
        {
          "tag": "cmdb.hostProfile",
          "value": "main"
        }
      ]
    },
    {
      "name": "host-profile-separate-1",
      "priority": 41,
      "when": {
        "anyRegex": [
          {
            "field": "hostProfile",
            "pattern": "(?i)^separate-profile-1$"
          }
        ]
      },
      "tags": [
        {
          "tag": "cmdb.hostProfile",
          "value": "separate-profile-1"
        }
      ]
    },
    {
      "name": "host-profile-separate-2",
      "priority": 42,
      "when": {
        "anyRegex": [
          {
            "field": "hostProfile",
            "pattern": "(?i)^separate-profile-2$"
          }
        ]
      },
      "tags": [
        {
          "tag": "cmdb.hostProfile",
          "value": "separate-profile-2"
        }
      ]
    },
    {
      "name": "c2m-business-hours",
      "priority": 50,
      "when": {
        "anyRegex": [
          {
            "field": "monitoringPolicy",
            "pattern": "(?i)^monitor_business_hours$"
          }
        ]
      },
      "tags": [
        {
          "tag": "monitoring.policy",
          "value": "business_hours_08_18"
        }
      ]
    },
    {
      "name": "c2m-deep-reference-lookup",
      "priority": 60,
      "when": {
        "anyRegex": [
