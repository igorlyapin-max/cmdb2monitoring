{
  "schemaVersion": "0.1",
  "rulesVersion": "2026.05.02-dev-empty",
  "name": "cmdbuild-to-zabbix-host-create-dev-empty",
  "description": "Clean dev starter generated from the empty installation profile. Safe no-op until an operator fills dev source fields, Zabbix catalog IDs, host profiles, selection rules, T4 templates and sets publish=true for required event routes. Use the demo/e2e rules file for populated test scenarios.",
  "source": {
    "topic": "cmdbuild.webhooks.dev",
    "supportedEvents": [
      "create",
      "update",
      "delete"
    ],
    "hostCreateEvents": [
      "create"
    ],
    "entityClasses": [],
    "fields": {
      "entityId": {
        "source": "id",
        "required": true
      },
      "code": {
        "source": "code",
        "required": false
      },
      "className": {
        "source": "className",
        "required": true
      },
      "ipAddress": {
        "source": "ip_address",
        "required": false
      },
      "dnsName": {
        "source": "dns_name",
        "required": false
      },
      "description": {
        "source": "description",
        "required": false
      }
    }
  },
  "zabbix": {
    "apiEndpoint": "http://localhost:8081/api_jsonrpc.php",
    "method": "host.create",
    "auth": {
      "mode": "configuredTokenOrLogin",
      "tokenConfigKey": "Zabbix:ApiToken",
      "loginConfigKeys": {
        "user": "Zabbix:User",
        "password": "Zabbix:Password"
      }
    },
    "requiredHostCreateFields": [
      "host",
      "interfaces",
      "groups"
    ],
    "expectedMonitoringFields": [
      "host",
      "name",
      "interfaces[].ip",
      "interfaces[].dns",
      "interfaces[].useip",
      "groups[].groupid",
      "templates[].templateid",
      "tags[].tag",
      "tags[].value"
    ]
  },
  "lookups": {},
