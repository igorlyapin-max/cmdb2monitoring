  "normalization": {
    "hostName": {
      "inputPriority": [
        "code",
        "id"
      ],
      "prefixTemplate": "cmdb-<#= Model.ClassName #>-",
      "regexReplacements": [
        {
          "pattern": "[^A-Za-z0-9_.-]+",
          "replacement": "-"
        },
        {
          "pattern": "^-+|-+$",
          "replacement": ""
        }
      ],
      "lowercase": true,
      "fallbackTemplate": "cmdb-<#= Model.ClassName #>-<#= Model.EntityId #>"
    },
    "visibleName": {
      "template": "<#= Model.ClassName #> <#= Model.Code ?? Model.EntityId #>"
    }
  },
  "eventRoutingRules": [
    {
      "eventType": "create",
      "method": "host.create",
      "templateName": "hostCreateJsonRpcRequestLines",
      "requiresZabbixHostId": false,
      "requiredFields": [
        "entityId",
        "className",
        "interfaceAddress"
      ],
      "publish": false
    },
    {
      "eventType": "update",
      "method": "host.update",
      "templateName": "hostUpdateJsonRpcRequestLines",
      "requiresZabbixHostId": true,
      "fallbackMethod": "host.get",
      "fallbackTemplateName": "hostGetByHostJsonRpcRequestLines",
      "requiredFields": [
        "entityId",
        "className",
        "interfaceAddress"
      ],
      "publish": false
    },
    {
      "eventType": "delete",
      "method": "host.delete",
      "templateName": "hostDeleteJsonRpcRequestLines",
      "requiresZabbixHostId": true,
      "fallbackMethod": "host.get",
      "fallbackTemplateName": "hostGetByHostJsonRpcRequestLines",
      "requiredFields": [
        "entityId",
        "className"
      ],
      "publish": false
    }
  ],
  "monitoringSuppressionRules": [],
  "hostProfiles": [],
  "selectionPolicy": {
    "ruleOrder": "ascendingPriority",
    "groupSelection": "mergeAllMatchesOrFallback",
    "templateSelection": "mergeAllMatchesOrFallback",
    "hostProfileSelection": "allMatchedProfiles",
    "interfaceSelection": "firstMatchOrFallback",
    "tagSelection": "mergeDefaultsAndMatches",
    "deduplicateBy": {
      "hostGroups": "groupid",
      "templates": "templateid",
      "tags": "tag"
    }
  },
