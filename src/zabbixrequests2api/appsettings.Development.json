{
  "Service": {
    "Name": "zabbixrequests2api-dev",
    "HealthRoute": "/health"
  },
  "Kafka": {
    "Input": {
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbix.host.requests.dev",
      "GroupId": "zabbixrequests2api-dev",
      "ClientId": "zabbixrequests2api-consumer-dev",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": ""
    },
    "Output": {
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbix.host.responses.dev",
      "ClientId": "zabbixrequests2api-producer-dev",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": ""
    }
  },
  "Zabbix": {
    "ApiEndpoint": "http://localhost:8081/api_jsonrpc.php",
    "AuthMode": "LoginOrToken",
    "ApiToken": "",
    "User": "Admin",
    "Password": "zabbix",
    "RequestTimeoutMs": 30000,
    "ValidateHostGroups": true,
    "ValidateTemplates": true,
    "ValidateTemplateGroups": true,
    "ValidateTemplateCompatibility": true,
    "AllowDynamicHostGroupCreate": true
  },
  "Processing": {
    "DelayBetweenObjectsMs": 2000,
    "MaxRetryAttempts": 3,
    "RetryDelayMs": 5000
  },
  "ProcessingState": {
    "FilePath": "state/zabbixrequests2api-state.dev.json",
    "WriteOnSuccess": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ElkLogging": {
    "Enabled": true,
    "Mode": "Kafka",
    "Elk": {
      "Enabled": false,
      "Endpoint": "",
      "Index": "zabbixrequests2api-logs-dev",
      "ApiKey": ""
    },
    "Kafka": {
      "Enabled": true,
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbixrequests2api.logs.dev",
      "ClientId": "zabbixrequests2api-logs-dev",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageTimeoutMs": 30000,
      "MinimumLevel": "Information",
      "ServiceName": "zabbixrequests2api",
      "Environment": "Development",
      "FlushTimeoutMs": 5000
    }
  }
}
