{
  "Service": {
    "Name": "zabbixrequests2api",
    "HealthRoute": "/health"
  },
  "Kafka": {
    "Input": {
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbix.host.requests",
      "GroupId": "zabbixrequests2api",
      "ClientId": "zabbixrequests2api-consumer",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "AutoOffsetReset": "Earliest",
      "EnableAutoCommit": false,
      "PollTimeoutMs": 1000
    },
    "Output": {
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbix.host.responses",
      "ClientId": "zabbixrequests2api-producer",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageTimeoutMs": 30000,
      "SuccessHeaderName": "zabbix-success",
      "MethodHeaderName": "zabbix-method",
      "ErrorCodeHeaderName": "zabbix-error-code"
    }
  },
  "Zabbix": {
    "ApiEndpoint": "http://localhost:8081/api_jsonrpc.php",
    "AuthMode": "LoginOrToken",
    "ApiToken": "",
    "User": "",
    "Password": "",
    "RequestTimeoutMs": 30000,
    "ValidateHostGroups": true,
    "ValidateTemplates": true,
    "ValidateTemplateGroups": true,
    "ValidateTemplateCompatibility": true,
    "AllowDynamicHostGroupCreate": true
  },
  "Processing": {
    "DelayBetweenObjectsMs": 2000,
    "MaxRetryAttempts": 3,
    "RetryDelayMs": 5000
  },
  "ProcessingState": {
    "FilePath": "state/zabbixrequests2api-state.json",
    "WriteOnSuccess": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ElkLogging": {
    "Enabled": true,
    "Mode": "Kafka",
    "Elk": {
      "Enabled": false,
      "Endpoint": "",
      "Index": "zabbixrequests2api-logs",
      "ApiKey": ""
    },
    "Kafka": {
      "Enabled": true,
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbixrequests2api.logs",
      "ClientId": "zabbixrequests2api-logs",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageTimeoutMs": 30000,
      "MinimumLevel": "Information",
      "ServiceName": "zabbixrequests2api",
      "Environment": "Production",
      "FlushTimeoutMs": 5000
    }
  },
  "AllowedHosts": "*"
}
