  "ElkLogging": {
    "Enabled": true,
    "Mode": "Kafka",
    "Elk": {
      "Enabled": false,
      "Endpoint": "",
      "Index": "zabbixbindings2cmdbuild-logs-dev",
      "ApiKey": ""
    },
    "Kafka": {
      "Enabled": true,
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbixbindings2cmdbuild.logs.dev",
      "ClientId": "zabbixbindings2cmdbuild-logs-dev",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageTimeoutMs": 30000,
      "MinimumLevel": "Information",
      "ServiceName": "zabbixbindings2cmdbuild",
      "Environment": "Development",
      "FlushTimeoutMs": 5000
    }
  }
}
