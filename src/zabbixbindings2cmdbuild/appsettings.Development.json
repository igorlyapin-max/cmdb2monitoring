{
  "Service": {
    "Name": "zabbixbindings2cmdbuild-dev",
    "HealthRoute": "/health"
  },
  "Kafka": {
    "Input": {
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbix.host.bindings.dev",
      "GroupId": "zabbixbindings2cmdbuild-dev",
      "ClientId": "zabbixbindings2cmdbuild-consumer-dev",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": ""
    }
  },
  "Cmdbuild": {
    "BaseUrl": "http://localhost:8090/cmdbuild/services/rest/v3",
    "Username": "admin",
    "Password": "admin",
    "RequestTimeoutMs": 10000
  },
  "ProcessingState": {
    "FilePath": "state/zabbixbindings2cmdbuild-state.dev.json"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
