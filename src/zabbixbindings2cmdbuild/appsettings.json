{
  "Service": {
    "Name": "zabbixbindings2cmdbuild",
    "HealthRoute": "/health"
  },
  "Secrets": {
    "Provider": "None",
    "References": {},
    "IndeedPamAapm": {
      "BaseUrl": "",
      "PasswordEndpointPath": "/sc_aapm_ui/rest/aapm/password",
