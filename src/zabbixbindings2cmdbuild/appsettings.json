      "EnableAutoCommit": false,
      "PollTimeoutMs": 1000
    }
  },
  "Cmdbuild": {
    "BaseUrl": "http://localhost:8090/cmdbuild/services/rest/v3",
    "Username": "",
    "Password": "",
