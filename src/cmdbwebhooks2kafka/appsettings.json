{
  "Service": {
    "Name": "cmdbwebhooks2kafka",
    "HealthRoute": "/health"
  },
  "Secrets": {
    "Provider": "None",
    "References": {},
    "IndeedPamAapm": {
      "BaseUrl": "",
      "PasswordEndpointPath": "/sc_aapm_ui/rest/aapm/password",
      "ApplicationToken": "",
      "ApplicationTokenFile": "",
      "ApplicationUsername": "",
      "ApplicationPassword": "",
      "DefaultAccountPath": "",
      "SendApplicationCredentialsInQuery": false,
      "ResponseType": "json",
      "ValueJsonPath": "password",
      "PasswordExpirationInMinute": "30",
      "PasswordChangeRequired": false,
      "Comment": "cmdb2monitoring {service} {secretId}",
      "TenantId": "",
      "TimeoutMs": 10000
    }
  },
  "CmdbWebhook": {
    "Route": "/webhooks/cmdbuild",
    "EndpointTag": "CMDBuild",
    "Source": "cmdbuild",
    "UnknownEventType": "unknown",
    "EventTypeFields": [
      "eventType",
      "event",
      "type",
      "operation"
    ],
    "EntityTypeFields": [
      "className",
      "class",
      "entityType",
      "typeName"
    ],
    "EntityIdFields": [
      "id",
      "code",
      "entityId"
    ],
    "SearchContainers": [
      "data",
      "card",
      "_card",
      "object",
      "payload"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "cmdbuild.webhooks",
    "ClientId": "cmdbwebhooks2kafka",
    "SecurityProtocol": "Plaintext",
    "SaslMechanism": "",
    "Username": "",
    "Password": "",
    "Acks": "All",
    "EnableIdempotence": true,
    "MessageTimeoutMs": 30000,
    "SourceHeaderName": "source",
    "EventTypeHeaderName": "eventType"
  },
  "ElkLogging": {
    "Enabled": true,
    "Mode": "Kafka",
    "Elk": {
      "Enabled": false,
      "Endpoint": "",
      "Index": "cmdbwebhooks2kafka-logs",
      "ApiKey": ""
    },
    "Kafka": {
      "Enabled": true,
      "BootstrapServers": "localhost:9092",
      "Topic": "cmdbwebhooks2kafka.logs",
      "ClientId": "cmdbwebhooks2kafka-logs",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageTimeoutMs": 30000,
      "MinimumLevel": "Information",
      "ServiceName": "cmdbwebhooks2kafka",
      "Environment": "Production",
      "FlushTimeoutMs": 5000
    }
  },
  "AllowedHosts": "*"
}
