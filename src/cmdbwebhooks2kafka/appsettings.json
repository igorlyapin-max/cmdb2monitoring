{
  "Service": {
    "Name": "cmdbwebhooks2kafka",
    "HealthRoute": "/health"
  },
  "CmdbWebhook": {
    "Route": "/webhooks/cmdbuild",
    "EndpointTag": "CMDBuild",
    "Source": "cmdbuild",
    "UnknownEventType": "unknown",
    "EventTypeFields": [
      "eventType",
      "event",
      "type",
      "operation"
    ],
    "EntityTypeFields": [
      "className",
      "class",
      "entityType",
      "typeName"
    ],
    "EntityIdFields": [
      "id",
      "code",
      "entityId"
    ],
    "SearchContainers": [
      "data",
      "card",
      "_card",
      "object",
      "payload"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "cmdbuild.webhooks",
    "ClientId": "cmdbwebhooks2kafka",
    "SecurityProtocol": "Plaintext",
    "SaslMechanism": "",
    "Username": "",
    "Password": "",
    "Acks": "All",
    "EnableIdempotence": true,
    "MessageTimeoutMs": 30000,
    "SourceHeaderName": "source",
    "EventTypeHeaderName": "eventType",
    "TopicProvisioning": {
      "Enabled": true,
      "Partitions": 1,
      "ReplicationFactor": 1,
      "RequestTimeoutMs": 10000,
      "FailOnError": true
    }
  },
  "ElkLogging": {
    "Enabled": true,
    "Mode": "Kafka",
    "Elk": {
      "Enabled": false,
      "Endpoint": "",
      "Index": "cmdbwebhooks2kafka-logs",
      "ApiKey": ""
    },
    "Kafka": {
      "Enabled": true,
      "BootstrapServers": "localhost:9092",
      "Topic": "cmdbwebhooks2kafka.logs",
      "ClientId": "cmdbwebhooks2kafka-logs",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageTimeoutMs": 30000,
      "MinimumLevel": "Information",
      "ServiceName": "cmdbwebhooks2kafka",
      "Environment": "Production",
      "FlushTimeoutMs": 5000,
      "TopicProvisioning": {
        "Enabled": true,
        "Partitions": 1,
        "ReplicationFactor": 1,
        "RequestTimeoutMs": 10000,
        "FailOnError": true
      }
    }
  },
  "AllowedHosts": "*"
}
