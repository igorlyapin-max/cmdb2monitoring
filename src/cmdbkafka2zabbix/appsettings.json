{
  "Service": {
    "Name": "cmdbkafka2zabbix",
    "HealthRoute": "/health",
    "RulesReloadRoute": "/admin/reload-rules",
    "RulesReloadToken": "",
    "RulesStatusRoute": "/admin/rules-status",
    "RulesStatusToken": ""
  },
  "Secrets": {
    "Provider": "None",
    "References": {},
    "IndeedPamAapm": {
      "BaseUrl": "",
      "PasswordEndpointPath": "/sc_aapm_ui/rest/aapm/password",
      "ApplicationToken": "",
      "ApplicationTokenFile": "",
      "ApplicationUsername": "",
      "ApplicationPassword": "",
      "DefaultAccountPath": "",
      "SendApplicationCredentialsInQuery": false,
      "ResponseType": "json",
      "ValueJsonPath": "password",
      "PasswordExpirationInMinute": "30",
      "PasswordChangeRequired": false,
      "Comment": "cmdb2monitoring {service} {secretId}",
      "TenantId": "",
      "TimeoutMs": 10000
    }
  },
  "Kafka": {
    "Input": {
      "BootstrapServers": "localhost:9092",
      "Topic": "cmdbuild.webhooks",
      "GroupId": "cmdbkafka2zabbix",
      "ClientId": "cmdbkafka2zabbix-consumer",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "AutoOffsetReset": "Earliest",
      "EnableAutoCommit": false,
      "PollTimeoutMs": 1000
    },
    "Output": {
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbix.host.requests",
      "ClientId": "cmdbkafka2zabbix-producer",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageTimeoutMs": 30000,
      "MethodHeaderName": "zabbix-method",
      "EventTypeHeaderName": "eventType",
      "EntityIdHeaderName": "entityId",
      "ProfileHeaderName": "cmdb2monitoring-profile"
    }
  },
  "ConversionRules": {
    "RepositoryPath": "../..",
    "ReadFromGit": false,
    "RepositoryUrl": "",
    "RulesFilePath": "rules/cmdbuild-to-zabbix-host-create.json",
    "PullOnStartup": false,
    "PullOnReload": false,
    "GitExecutablePath": "git",
    "TemplateEngine": "Mono.TextTemplating",
    "TemplateName": "hostCreateJsonRpcRequestLines",
    "AddDefaultDirectives": true
  },
  "Cmdbuild": {
    "Enabled": true,
    "BaseUrl": "",
    "Username": "",
    "Password": "",
    "RequestTimeoutMs": 10000,
    "MaxPathDepth": 2,
    "HostBindingLookupEnabled": true,
    "MainHostIdAttributeName": "zabbix_main_hostid",
    "BindingClassName": "ZabbixHostBinding",
    "BindingLookupLimit": 1000
  },
  "ProcessingState": {
    "FilePath": "state/cmdbkafka2zabbix-state.json",
    "WriteOnSuccess": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ElkLogging": {
    "Enabled": true,
    "Mode": "Kafka",
    "Elk": {
      "Enabled": false,
      "Endpoint": "",
      "Index": "cmdbkafka2zabbix-logs",
      "ApiKey": ""
    },
    "Kafka": {
      "Enabled": true,
      "BootstrapServers": "localhost:9092",
      "Topic": "cmdbkafka2zabbix.logs",
      "ClientId": "cmdbkafka2zabbix-logs",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageTimeoutMs": 30000,
      "MinimumLevel": "Information",
      "ServiceName": "cmdbkafka2zabbix",
      "Environment": "Production",
      "FlushTimeoutMs": 5000
    }
  },
  "AllowedHosts": "*"
}
