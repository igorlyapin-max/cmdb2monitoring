{
  "Service": {
    "Name": "cmdbkafka2zabbix-dev",
    "HealthRoute": "/health"
  },
  "Kafka": {
    "Input": {
      "BootstrapServers": "localhost:9092",
      "Topic": "cmdbuild.webhooks.dev",
      "GroupId": "cmdbkafka2zabbix-dev",
      "ClientId": "cmdbkafka2zabbix-consumer-dev",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": ""
    },
    "Output": {
      "BootstrapServers": "localhost:9092",
      "Topic": "zabbix.host.requests.dev",
      "ClientId": "cmdbkafka2zabbix-producer-dev",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": ""
    }
  },
  "ConversionRules": {
    "RepositoryPath": "../..",
    "RulesFilePath": "rules/cmdbuild-to-zabbix-host-create.json",
    "PullOnStartup": false,
    "GitExecutablePath": "git",
    "TemplateEngine": "Mono.TextTemplating",
    "TemplateName": "hostCreateJsonRpcRequestLines",
    "AddDefaultDirectives": true
  },
  "Cmdbuild": {
    "Enabled": true,
    "BaseUrl": "http://localhost:8090/cmdbuild/services/rest/v3",
    "Username": "admin",
    "Password": "admin",
    "RequestTimeoutMs": 10000,
    "MaxPathDepth": 5
  },
  "ProcessingState": {
    "FilePath": "state/cmdbkafka2zabbix-state.dev.json",
    "WriteOnSuccess": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ElkLogging": {
    "Enabled": true,
    "Mode": "Kafka",
    "Elk": {
      "Enabled": false,
      "Endpoint": "",
      "Index": "cmdbkafka2zabbix-logs-dev",
      "ApiKey": ""
    },
    "Kafka": {
      "Enabled": true,
      "BootstrapServers": "localhost:9092",
      "Topic": "cmdbkafka2zabbix.logs.dev",
      "ClientId": "cmdbkafka2zabbix-logs-dev",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "",
      "Username": "",
      "Password": "",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageTimeoutMs": 30000,
      "MinimumLevel": "Information",
      "ServiceName": "cmdbkafka2zabbix",
      "Environment": "Development",
      "FlushTimeoutMs": 5000
    }
  }
}
